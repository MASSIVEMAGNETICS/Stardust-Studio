# Stardust Studio Environment
# Copy to .env and fill in your values

# Primary LLM provider (OpenAI compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Optional: GitHub token with repo scope for pushing generated products
GITHUB_TOKEN=ghp_...

# Optional: Your GitHub username (for constructing clone URLs)
GITHUB_USERNAME=yourusername